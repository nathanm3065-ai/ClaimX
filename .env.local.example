# Copy this file to .env.local and fill in your key.
# Get a key at https://console.anthropic.com/

ANTHROPIC_API_KEY=sk-ant-...

# Optional: override the model used for the AI pipeline.
# Defaults to claude-opus-4-8 (vision-capable, most capable).
# claude-sonnet-4-6 is a faster / cheaper alternative that also supports vision.
CLAUDE_MODEL=claude-opus-4-8
